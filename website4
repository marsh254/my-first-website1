<!DOCTYPE html>
<html>
<head>
  <title>🌱 Farmers Crop Updates</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: linear-gradient(to bottom, #d0f0c0, #ffffff);
      margin: 0;
      padding: 0;
      text-align: center;
    }

    h1 {
      color: #2e7d32;
      margin-top: 20px;
    }

    .crop-box {
      background: white;
      padding: 20px;
      margin: 20px auto;
      border-radius: 15px;
      width: 90%;
      max-width: 400px;
      box-shadow: 0px 4px 8px rgba(0,0,0,0.2);
    }

    .crop-box img {
      width: 100%;
      border-radius: 10px;
    }

    button {
      padding: 10px 20px;
      margin-top: 10px;
      background-color: #4caf50;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 16px;
    }

    button:hover {
      background-color: #388e3c;
    }

    p {
      font-size: 16px;
      margin-top: 10px;
      min-height: 40px;
    }

    footer {
      margin: 20px;
      color: #555;
    }
  </style>
</head>

<body>

  <h1>🌾 Farmers Crop Updates</h1>

  <!-- Maize -->
  <div class="crop-box">
    <h2>Maize</h2>
    <img src="https://upload.wikimedia.org/wikipedia/commons/0/05/Maize_closeup.jpg" alt="Maize">
    <p id="maize">Tap the button to get updates.</p>
    <button onclick="updateMaize()">Check Maize Update</button>
  </div>

  <!-- Beans -->
  <div class="crop-box">
    <h2>Beans</h2>
    <img src="https://upload.wikimedia.org/wikipedia/commons/3/3d/Common_beans.jpg" alt="Beans">
    <p id="beans">Tap the button to get updates.</p>
    <button onclick="updateBeans()">Check Beans Update</button>
  </div>

  <!-- Weather -->
  <div class="crop-box">
    <h2>Weather Advice</h2>
    <img src="https://upload.wikimedia.org/wikipedia/commons/1/1b/Weather_icon.png" alt="Weather">
    <p id="weather">Tap the button to get advice.</p>
    <button onclick="updateWeather()">Check Weather</button>
  </div>

  <footer>
    Made for Kenyan Farmers 🌱
  </footer>

  <script>
    const maizeUpdates = [
      "Maize is in early growth stage. Apply fertilizer.",
      "Maize is growing well. Watch for pests.",
      "Maize nearing harvest stage.",
      "Maize ready for harvesting."
    ];

    const beansUpdates = [
      "Beans just planted. Ensure enough water.",
      "Beans flowering stage. Add nutrients.",
      "Beans forming pods.",
      "Beans ready for harvest."
    ];

    const weatherTips = [
      "Expect rain this week. Good for planting.",
      "Dry conditions. Irrigate crops.",
      "Moderate weather. Maintain crops.",
      "Heavy rain expected. Improve drainage."
    ];

    function updateMaize() {
      const random = Math.floor(Math.random() * maizeUpdates.length);
      document.getElementById("maize").innerText = maizeUpdates[random];
    }

    function updateBeans() {
      const random = Math.floor(Math.random() * beansUpdates.length);
      document.getElementById("beans").innerText = beansUpdates[random];
    }

    function updateWeather() {
      const random = Math.floor(Math.random() * weatherTips.length);
      document.getElementById("weather").innerText = weatherTips[random];
    }
  </script>

</body>
</html>
